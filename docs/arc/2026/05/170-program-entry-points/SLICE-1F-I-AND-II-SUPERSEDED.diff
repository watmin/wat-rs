//! Arc 170 slice 1f-ii — integration tests for `:wat::kernel::StdOutService`.
//!
//! These tests exercise the public API of [`wat::services::stdout`]:
//!
//! - [`wat::services::start_stdout_service`] singleton idempotency
//! - [`wat::services::StdOutService::spawn_for_test`] hermetic-test path
//! - per-thread `register` / `unregister` roundtrip
//! - send-with-ack mini-TCP discipline
//! - HolonAST → wire-format EDN serialization
//! - parametric-keyword wire encoding (slice 1f-W) applied transparently
//! - multi-thread concurrent producers
//! - shutdown drains pending messages
//! - fd ownership convention
//!
//! Each non-singleton test allocates its own pipe pair via
//! [`libc::pipe`]; the service writes to the pipe's write end, the
//! test reads from the read end. Dropping the test handle issues
//! `Shutdown` to the worker (drain-then-exit). The test reads the
//! drained bytes by polling the pipe's read end after handle drop.

use crossbeam_channel::{bounded, Sender};
use holon::HolonAST;
use std::os::fd::{AsRawFd, FromRawFd, OwnedFd};
use std::sync::Arc;
use std::time::{Duration, Instant};
use wat::services::stdout::{
    start_stdout_service, AckSender, ControlMsg, Message, StdOutService, StdOutServiceHandle,
};

// ─── Test infrastructure ────────────────────────────────────────────────────

/// Allocate a pipe pair for test output. Returns `(read_fd, write_fd)`
/// both as [`OwnedFd`]; caller transfers `write_fd.as_raw_fd()` to
/// the service via `spawn_for_test`. Service writes to `write_fd`;
/// caller reads from `read_fd` to observe output.
fn make_test_pipe() -> (OwnedFd, OwnedFd) {
    let mut fds = [0i32; 2];
    let ret = unsafe { libc::pipe(fds.as_mut_ptr()) };
    assert_eq!(ret, 0, "test pipe(2) must succeed");
    let r = unsafe { OwnedFd::from_raw_fd(fds[0]) };
    let w = unsafe { OwnedFd::from_raw_fd(fds[1]) };
    (r, w)
}

/// Read up to `max_bytes` from `fd` with a deadline. Loops on
/// `libc::read` until enough bytes accumulate or the deadline
/// passes. Returns whatever was collected.
fn read_until(fd: &OwnedFd, max_bytes: usize, deadline: Instant) -> Vec<u8> {
    set_nonblocking(fd);
    let mut out: Vec<u8> = Vec::with_capacity(max_bytes);
    let mut chunk = [0u8; 4096];
    while out.len() < max_bytes && Instant::now() < deadline {
        let n = unsafe {
            libc::read(
                fd.as_raw_fd(),
                chunk.as_mut_ptr() as *mut libc::c_void,
                chunk.len(),
            )
        };
        if n > 0 {
            out.extend_from_slice(&chunk[..n as usize]);
            continue;
        }
        if n == 0 {
            // EOF — write end closed, no more data ever.
            break;
        }
        // n < 0 — EAGAIN/EWOULDBLOCK / EINTR. Sleep a bit, retry.
        let errno = std::io::Error::last_os_error()
            .raw_os_error()
            .unwrap_or(0);
        if errno == libc::EAGAIN || errno == libc::EWOULDBLOCK || errno == libc::EINTR {
            std::thread::sleep(Duration::from_millis(5));
            continue;
        }
        break;
    }
    out
}

/// Mark `fd` as O_NONBLOCK so `read` returns EAGAIN instead of
/// blocking. Required for the deadline-driven read loop above —
/// otherwise `read` blocks forever waiting for the pipe's other
/// end to close, and our deadline never trips.
fn set_nonblocking(fd: &OwnedFd) {
    unsafe {
        let flags = libc::fcntl(fd.as_raw_fd(), libc::F_GETFL, 0);
        if flags >= 0 {
            libc::fcntl(fd.as_raw_fd(), libc::F_SETFL, flags | libc::O_NONBLOCK);
        }
    }
}

/// Standard test timeout — generous enough that a healthy service
/// will not hit it, tight enough that a hung test fails in seconds.
const TEST_TIMEOUT: Duration = Duration::from_secs(2);

/// A unique test thread_id derived from the current thread.
fn current_tid() -> std::thread::ThreadId {
    std::thread::current().id()
}

/// Build a one-shot ack pair. The service signals `()` after the
/// libc::write completes; the producer blocks on the receiver.
fn make_ack() -> (AckSender, crossbeam_channel::Receiver<()>) {
    bounded::<()>(1)
}

/// Send a HolonAST through the producer-side Sender and block on the
/// ack with `timeout`. Returns the ack outcome (`Ok(())` on success).
fn send_and_wait(
    tx: &Sender<Message>,
    ast: HolonAST,
    timeout: Duration,
) -> Result<(), crossbeam_channel::RecvTimeoutError> {
    let (ack_tx, ack_rx) = make_ack();
    tx.send((Arc::new(ast), ack_tx))
        .expect("producer Sender must accept the message; service worker is alive");
    ack_rx.recv_timeout(timeout)
}

