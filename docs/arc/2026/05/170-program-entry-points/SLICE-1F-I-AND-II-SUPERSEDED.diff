// ─── Public API ─────────────────────────────────────────────────────────────

/// One-shot ack sender. The producer creates a `bounded(1)` pair
/// per send; the service signals `()` after the libc::write
/// completes. Producers block on the matching Receiver to wait for
/// kernel-buffer landing.
pub type AckSender = Sender<()>;

/// One-shot ack receiver. Counterpart to [`AckSender`].
pub type AckReceiver = Receiver<()>;

/// Per-message payload sent over a thread's data channel.
/// `Arc<HolonAST>` so the producer can keep its own reference for
/// post-ack inspection if desired.
pub type Message = (Arc<HolonAST>, AckSender);

/// Singleton handle to the process-wide [`StdOutService`] writing
/// to fd 1. Idempotent; the first call spawns the worker thread,
/// subsequent calls return the same `&'static` handle.
///
/// Wat-cli wires this into boot in slice 1f-iv. In-process tests
/// that exercise the singleton path inherit one shared service for
/// the cargo-test process; tests that need isolation should reach
/// for [`StdOutService::spawn_for_test`] instead.
pub fn start_stdout_service() -> &'static StdOutServiceHandle {
    static SINGLETON: OnceLock<StdOutServiceHandle> = OnceLock::new();
    SINGLETON.get_or_init(|| StdOutService::spawn_internal(libc::STDOUT_FILENO))
}

/// Per-thread service-control message. Sent over the handle's
/// crossbeam control channel; the worker drains the channel after
/// any Select wakeup.
#[derive(Debug)]
pub enum ControlMsg {
    /// Register a producer for `thread_id`. The service stores the
    /// `Receiver` end and adds it to the Select set on the next
    /// iteration.
    Register {
        thread_id: ThreadId,
        receiver: Receiver<Message>,
    },
    /// Unregister the producer for `thread_id`. The stored
    /// `Receiver` drops; the corresponding `Sender` will see
    /// disconnect on next send.
    Unregister { thread_id: ThreadId },
    /// Shutdown the service worker thread. Drains all pending
    /// per-thread messages (each serialized, written, and acked)
    /// before exiting. Used by [`StdOutServiceHandle::Drop`] on
    /// test handles — the singleton handle is `&'static` and
    /// never receives this.
    Shutdown,
}

/// Service handle. Holds the control-channel sender. Cheaply
/// cloneable via reference (the singleton is `&'static`); test
/// handles are owned values whose `Drop` issues `Shutdown` and
/// lets the worker drain + terminate.
pub struct StdOutServiceHandle {
    /// Crossbeam sender for control messages. The worker holds the
    /// matching receiver in its Select set.
    control_tx: Sender<ControlMsg>,

    /// True once `Shutdown` has been signaled. Idempotent — we
    /// accept double-drop attempts on test handles silently.
    shutdown_signaled: AtomicBool,

    /// True for handles produced by [`StdOutService::spawn_for_test`].
    /// Drop signals shutdown; singleton drop is a no-op (the
    /// `&'static` handle is never dropped in practice — the
    /// `OnceLock`-stored value lives the process lifetime).
    is_test_handle: bool,
}

impl StdOutServiceHandle {
    /// Register a producer thread. Returns a [`Sender`] the thread
    /// uses to feed `(Arc<HolonAST>, AckSender)` messages. The
    /// service stores the matching Receiver in its Select set; on
    /// readiness the worker serializes the HolonAST to EDN, writes
    /// to its output fd, and signals the ack.
    ///
    /// The control message is queued; registration is async — if
    /// the caller sends a message immediately after `register`
    /// returns, the worker may still be processing the registration
    /// on its next loop iteration. The crossbeam channel buffers
    /// the producer's send until the worker's Select picks it up;
    /// the producer's ack-Receiver guarantees per-message ordering
    /// (a producer that blocks on its ack before sending the next
    /// message sees its writes land in submission order).
    pub fn register(&self, thread_id: ThreadId) -> Sender<Message> {
        let (tx, rx) = unbounded::<Message>();
        // Crossbeam send only fails if the worker has dropped its
        // receiver (worker exited). We swallow that — the caller's
        // returned Sender will simply error on send. A failed wakeup
        // on a dead worker is moot.
        let _ = self.control_tx.send(ControlMsg::Register {
            thread_id,
            receiver: rx,
        });
        tx
    }

    /// Unregister the producer for `thread_id`. Drops the worker's
    /// stored Receiver; the corresponding Sender sees disconnect
    /// on next send. Idempotent — unregistering an unknown
    /// thread_id is a no-op.
    pub fn unregister(&self, thread_id: ThreadId) {
        let _ = self
            .control_tx
            .send(ControlMsg::Unregister { thread_id });
    }
}

impl Drop for StdOutServiceHandle {
    fn drop(&mut self) {
        if !self.is_test_handle {
            // Singleton — never actually dropped (OnceLock holds
            // it for process lifetime); but be defensive.
            return;
        }
        if self.shutdown_signaled.swap(true, Ordering::SeqCst) {
            return;
        }
        let _ = self.control_tx.send(ControlMsg::Shutdown);
    }
}

// ─── Service struct ─────────────────────────────────────────────────────────

/// Marker type for the service. Callers don't construct this
/// directly — they reach for [`start_stdout_service`] (production)
/// or [`StdOutService::spawn_for_test`] (Rust integration tests).
pub struct StdOutService;

impl StdOutService {
    /// Spawn a fresh, non-singleton StdOutService writing to
    /// `output_fd`. Returns a [`StdOutServiceHandle`] whose `Drop`
    /// shuts down the worker (drain-then-exit).
    ///
    /// Designed for hermetic Rust integration tests: each test
    /// allocates its own pipe pair, hands the write end to
    /// `spawn_for_test`, reads from the read end to observe output,
    /// and drops the handle to clean up. This shape lets multiple
    /// tests run in the same cargo-test process without contending
    /// over the singleton's fd 1 or each other.
    ///
    /// `output_fd` ownership: the caller retains ownership. The
    /// service uses the fd via `libc::write` but does not close it
    /// — the caller's [`OwnedFd`] (or equivalent) outlives the
    /// service or the test cleans up explicitly.
    pub fn spawn_for_test(output_fd: RawFd) -> StdOutServiceHandle {
        let mut handle = Self::spawn_internal(output_fd);
        handle.is_test_handle = true;
        handle
    }

    /// Internal common path: allocate the crossbeam control
    /// channel, spawn the worker, return the handle. Panics on
    /// thread-spawn failure with a diagnostic — the service can't
    /// operate without its worker thread, and silent degradation
    /// would mask the failure (per
    /// `feedback_shim_panic_vs_option.md` — construction-time
    /// failures panic with diagnostic).
    fn spawn_internal(output_fd: RawFd) -> StdOutServiceHandle {
        let (control_tx, control_rx) = unbounded::<ControlMsg>();

        thread::Builder::new()
            .name("wat::kernel::StdOutService".into())
            .spawn(move || {
                run_service_loop(output_fd, control_rx);
            })
            // Failing to spawn a kernel-internal service thread is
            // a process-fatal condition; panic with diagnostic.
            .expect(
                "StdOutService: failed to spawn worker thread; \
                 process is out of threads or memory and the \
                 service cannot operate",
            );

        StdOutServiceHandle {
            control_tx,
            shutdown_signaled: AtomicBool::new(false),
            is_test_handle: false,
        }
    }
}

// ─── Worker loop ────────────────────────────────────────────────────────────

/// Per-producer registry entry. The worker stores the Receiver and
/// adds it to the Select set on each iteration. The thread-id key
/// in the parent `HashMap<ThreadId, Producer>` carries identity;
/// this struct just holds the channel half.
struct Producer {
    receiver: Receiver<Message>,
}

/// Worker entry point. Owns:
/// - `output_fd`: the data fd (fd 1 or a test pipe write end)
/// - `control_rx`: the crossbeam control channel
///
/// Multiplexes via [`crossbeam_channel::Select`] across the control
/// channel + N per-thread data Receivers. Rebuilds the Select set
/// each iteration (cheap; bounded by registered-thread count).
fn run_service_loop(output_fd: RawFd, control_rx: Receiver<ControlMsg>) {
    // Producer registry. HashMap keyed by ThreadId for O(1)
    // unregister; iteration order doesn't matter (Select picks
    // readiness, not order).
    let mut producers: HashMap<ThreadId, Producer> = HashMap::new();
    // Reusable EDN serialization buffer; capacity grows to the
    // largest message seen, then stabilizes — no per-message
    // allocation in the hot path.
    let mut buf = String::with_capacity(256);
    // Set when Shutdown control message received; loop drains
    // remaining producer messages then exits.
    let mut shutting_down = false;

    loop {
        // ── Snapshot the registry ────────────────────────────────
        //
        // Crossbeam's `SelectedOperation` borrows the receivers
        // passed to `Select::recv`. To avoid holding a borrow on
        // `producers` across mutation (Register/Unregister/error-
        // remove), we snapshot `(ThreadId, Receiver)` pairs by
        // CLONING the receivers (cheap — Receivers are
        // Arc-backed). The Select set is built from the snapshot;
        // mutations happen on `producers` directly between
        // iterations.
        let snapshot: Vec<(ThreadId, Receiver<Message>)> = producers
            .iter()
            .map(|(tid, p)| (*tid, p.receiver.clone()))
            .collect();

        let mut sel = Select::new();
        sel.recv(&control_rx);
        for (_tid, rx) in &snapshot {
            sel.recv(rx);
        }

        // ── Block until any channel is ready ─────────────────────
        let oper = sel.select();
        let idx = oper.index();

        if idx == 0 {
            // Control channel fired. Receive the operation we
            // committed to via `select`, then drain any further
            // pending control messages with try_recv.
            match oper.recv(&control_rx) {
                Ok(msg) => handle_control(msg, &mut producers, &mut shutting_down),
                Err(_) => {
                    // Control sender dropped — no more handle
                    // references exist. Treat as Shutdown.
                    shutting_down = true;
                }
            }
            while let Ok(msg) = control_rx.try_recv() {
                handle_control(msg, &mut producers, &mut shutting_down);
            }
        } else {
            // A producer's data channel fired. Map index back to
            // its ThreadId via the snapshot's parallel position.
            let (tid, rx) = &snapshot[idx - 1];
            // Receive the operation we committed to via `select`
            // using the SAME cloned receiver — crossbeam's
            // SelectedOperation requires the original `&Receiver`
            // back.
            let recv_result = oper.recv(rx);
            match recv_result {
                Ok((ast, ack_tx)) => {
                    serialize_and_write(&ast, output_fd, &mut buf);
                    // Send the ack. Failure (producer dropped its
                    // ack receiver before we acked) is benign — the
                    // write happened; the producer just isn't
                    // listening for confirmation.
                    let _ = ack_tx.send(());
                }
                Err(_) => {
                    // Producer's Sender dropped (thread exited
                    // without unregistering). Drop our stored
                    // Receiver from the registry; the next iteration
                    // rebuilds Select without it.
                    producers.remove(tid);
                }
            }
        }

        // Snapshot's borrow of `producers` is finished — drop it
        // explicitly before the shutdown drain (which mutates).
        drop(snapshot);

        // ── Shutdown drain ───────────────────────────────────────
        //
        // If Shutdown was signaled, drain every remaining producer
        // message before exiting. Each drained message is serialized,
        // written, and acked normally. After the drain, exit the
        // loop; the worker thread terminates and our stored
        // Senders/Receivers drop.
        if shutting_down {
            drain_and_exit(&mut producers, output_fd, &mut buf);
            return;
        }
    }
}

/// Apply a control message to the producer registry. Sets
/// `shutting_down` on Shutdown; the caller's loop checks the flag
/// after handling control.
fn handle_control(
    msg: ControlMsg,
    producers: &mut HashMap<ThreadId, Producer>,
    shutting_down: &mut bool,
) {
    match msg {
        ControlMsg::Register {
            thread_id,
            receiver,
        } => {
            producers.insert(thread_id, Producer { receiver });
        }
        ControlMsg::Unregister { thread_id } => {
            producers.remove(&thread_id);
        }
        ControlMsg::Shutdown => {
            *shutting_down = true;
        }
    }
}

/// Drain every remaining message from every registered producer,
/// serialize + write + ack each one, then drop the registry. After
/// this returns, the worker exits its loop and its stored
/// Senders/Receivers drop, signalling disconnect to any producer
/// that's still alive.
fn drain_and_exit(
    producers: &mut HashMap<ThreadId, Producer>,
    output_fd: RawFd,
    buf: &mut String,
) {
    // Iterate by key to avoid borrowing the map while mutating.
    let tids: Vec<ThreadId> = producers.keys().copied().collect();
    for tid in tids {
        if let Some(p) = producers.get(&tid) {
            // Drain non-blocking; respect FIFO within each thread.
            while let Ok((ast, ack_tx)) = p.receiver.try_recv() {
                serialize_and_write(&ast, output_fd, buf);
                let _ = ack_tx.send(());
            }
        }
    }
    producers.clear();
}

/// Serialize `ast` to wire-format EDN (terminated with `\n`) and
/// write the bytes to `output_fd`. The buffer is reused across
/// calls; cleared each time.
///
/// Wire encoding is applied transparently by [`wat_edn::write_to`]:
/// keyword bodies inside `<...>` have their `,` replaced with `_`
/// per arc 170 slice 1f-W. Producers serialize parametric type
/// keywords (e.g. `:HashMap<K,V>`) and the wire output emits the
/// wire-safe form (`:HashMap<K_V>`).
///
/// libc::write errors are SILENTLY DROPPED. Slice 1f-iii's
/// StdErrService cascade owns the diagnostic-emit path; for
/// 1f-ii's stdout direction, a write error is a non-fatal pipe
/// failure (e.g., reader dropped) and the right behavior is to
/// keep the service alive so other producers can continue. The
/// alternative — panicking the worker — would tear down the
/// service mid-flight and break tests of normal flow. Documented
/// in SCORE-SLICE-1F-II.
fn serialize_and_write(ast: &HolonAST, output_fd: RawFd, buf: &mut String) {
    buf.clear();
    let edn = holon_ast_to_edn_value(ast);
    wat_edn::write_to(&edn, buf);
    buf.push('\n');
    let bytes = buf.as_bytes();
    let mut written = 0usize;
    while written < bytes.len() {
        // SAFETY: bytes points at a valid byte slice; libc::write
        // reads up to `len` bytes from it. The fd is the worker's
        // singleton-or-test-supplied output fd; the worker is the
        // only thread that writes it (single-writer guard).
        let n = unsafe {
            libc::write(
                output_fd,
                bytes[written..].as_ptr() as *const libc::c_void,
                bytes.len() - written,
            )
        };
        if n < 0 {
            let errno = std::io::Error::last_os_error()
                .raw_os_error()
                .unwrap_or(0);
            if errno == libc::EINTR {
                // Interrupted by signal; retry the same offset.
                continue;
            }
            // Pipe full / reader dropped / fd bad. Stop trying for
            // this message; the producer's ack still fires (the
            // worker has done what it can). Slice 1f-iii owns the
            // diagnostic cascade for fatal write errors.
            return;
        }
        if n == 0 {
            // Zero-byte write — pipe is full and would block. For
            // a blocking fd this shouldn't happen; defensive: stop.
            return;
        }
        written += n as usize;
    }
}

// ─── HolonAST → wat_edn::Value bridge ───────────────────────────────────────
//
// Slice 1f-i uses `read_holon_ast_natural` (public via edn_shim) for
// the parse direction. The write direction's analogue
// (`holon_ast_to_edn_natural` / `holon_ast_to_edn`) lives in
// `src/edn_shim.rs` but is private — the BRIEF Row O constraint
// forbids editing edn_shim.rs in this slice, so we reproduce the
// arm-for-arm logic here. Honest delta surfaced in
// SCORE-SLICE-1F-II: slice 3 sweep can promote this to a shared
// public helper alongside `read_holon_ast_natural`.
//
// Encoding choice: tagged form (`#wat-edn.holon/<variant>`) — the
// round-trip-safe shape that [`crate::edn_shim::read_holon_ast_tagged`]
// reads. This matches slice 1f-W's wire-encoding test where
// parametric-keyword Atoms must produce bytes containing the
// `<K_V>` underscore form; the tagged form preserves the keyword
// inside its `Symbol` payload so the writer's depth-aware swap
// fires exactly where pass 14 says it should.

/// Render a HolonAST as a tagged EDN value. Mirrors the private
/// `holon_ast_to_edn` in `src/edn_shim.rs`. Tagged form is
/// round-trip-safe via [`crate::edn_shim::read_holon_ast_tagged`].
fn holon_ast_to_edn_value(h: &HolonAST) -> OwnedValue {
    match h {
        HolonAST::Symbol(s) => OwnedValue::Tagged(
            Tag::ns("wat-edn.holon", "Symbol"),
            Box::new(OwnedValue::String(std::borrow::Cow::Owned(s.to_string()))),
        ),
        HolonAST::String(s) => OwnedValue::Tagged(
            Tag::ns("wat-edn.holon", "String"),
            Box::new(OwnedValue::String(std::borrow::Cow::Owned(s.to_string()))),
        ),
        HolonAST::I64(n) => OwnedValue::Tagged(
            Tag::ns("wat-edn.holon", "I64"),
            Box::new(OwnedValue::Integer(*n)),
        ),
        HolonAST::F64(x) => OwnedValue::Tagged(
            Tag::ns("wat-edn.holon", "F64"),
            Box::new(OwnedValue::Float(*x)),
        ),
        HolonAST::Bool(b) => OwnedValue::Tagged(
            Tag::ns("wat-edn.holon", "Bool"),
            Box::new(OwnedValue::Bool(*b)),
        ),
        HolonAST::Atom(inner) => OwnedValue::Tagged(
            Tag::ns("wat-edn.holon", "Atom"),
            Box::new(holon_ast_to_edn_value(inner)),
        ),
        HolonAST::Bind(role, filler) => OwnedValue::Tagged(
            Tag::ns("wat-edn.holon", "Bind"),
            Box::new(OwnedValue::Vector(vec![
                holon_ast_to_edn_value(role),
                holon_ast_to_edn_value(filler),
            ])),
        ),
        HolonAST::Bundle(xs) => OwnedValue::Tagged(
            Tag::ns("wat-edn.holon", "Bundle"),
            Box::new(OwnedValue::Vector(
                xs.iter().map(holon_ast_to_edn_value).collect(),
            )),
        ),
        HolonAST::Permute(child, k) => OwnedValue::Tagged(
