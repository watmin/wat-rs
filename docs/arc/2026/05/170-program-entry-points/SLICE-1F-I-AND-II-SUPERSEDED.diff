#[test]
fn row_h_shutdown_drains_pending() {
    let (read_fd, write_fd) = make_test_pipe();
    let handle = StdOutService::spawn_for_test(write_fd.as_raw_fd());

    let tx = handle.register(current_tid());

    // Queue a message but DON'T wait for ack — we want the message
    // sitting in the Receiver's queue when shutdown fires.
    let (ack_tx_a, ack_rx_a) = make_ack();
    tx.send((Arc::new(HolonAST::I64(101)), ack_tx_a))
        .expect("queue first message");

    // Wait for the ack to confirm the worker has processed message
    // 1 (so the worker is in a known state — back at Select).
    ack_rx_a
        .recv_timeout(TEST_TIMEOUT)
        .expect("first ack must arrive");

    // Now queue 2 more messages back-to-back; the worker may still
    // be processing message 1, or may already be back at Select.
    let (ack_tx_b, ack_rx_b) = make_ack();
    tx.send((Arc::new(HolonAST::I64(202)), ack_tx_b))
        .expect("queue second message");
    let (ack_tx_c, ack_rx_c) = make_ack();
    tx.send((Arc::new(HolonAST::I64(303)), ack_tx_c))
        .expect("queue third message");

    // Drop the handle — Shutdown fires; the worker drains the
    // Receiver before exiting. Both pending messages should still
    // get acked.
    drop(handle);

    // Both pending acks must arrive. If shutdown were
    // immediate-exit (the alternative design), these would
    // disconnect instead of acking.
    ack_rx_b
        .recv_timeout(TEST_TIMEOUT)
        .expect("second ack must arrive after shutdown drain");
    ack_rx_c
        .recv_timeout(TEST_TIMEOUT)
        .expect("third ack must arrive after shutdown drain");

    // Verify all three lines made it to the output fd.
    let deadline = Instant::now() + TEST_TIMEOUT;
    let bytes = read_until(&read_fd, 4096, deadline);
    let s = std::str::from_utf8(&bytes).expect("output must be valid UTF-8");
    for expected in &["101", "202", "303"] {
        assert!(
            s.contains(expected),
            "expected drained payload {} in output; got {:?}",
            expected,
            s
