    let tx = handle.register(current_tid());
    let bind = HolonAST::Bind(
        Arc::new(HolonAST::Symbol(Arc::from("role"))),
        Arc::new(HolonAST::String(Arc::from("filler"))),
    );
    send_and_wait(&tx, bind, TEST_TIMEOUT).expect("ack must arrive");

    let deadline = Instant::now() + TEST_TIMEOUT;
    let bytes = read_until(&read_fd, 1024, deadline);
