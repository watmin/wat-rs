#[test]
fn row_g_multi_thread_send_ack() {
    let (read_fd, write_fd) = make_test_pipe();
    let handle = StdOutService::spawn_for_test(write_fd.as_raw_fd());

    // Spawn N producer threads. Each registers under its own
    // ThreadId, sends one message, blocks on ack, then exits.
    const N: usize = 4;
    let mut joins = Vec::with_capacity(N);
    for i in 0..N {
        let h_ref: &StdOutServiceHandle =
            // SAFETY: the handle outlives all spawned threads
            // because we join all threads before dropping the
            // handle. The reference must be 'static for thread::spawn,
            // which we satisfy by leaking through a raw pointer.
            // For test code; production code lives in stdout.rs.
            unsafe { &*(&handle as *const StdOutServiceHandle) };
        let join = std::thread::spawn(move || {
            let tid = std::thread::current().id();
            let tx = h_ref.register(tid);
            let n = i as i64;
            send_and_wait(&tx, HolonAST::I64(n), TEST_TIMEOUT)
                .expect("each producer's ack must arrive");
            h_ref.unregister(tid);
        });
        joins.push(join);
    }
    for j in joins {
        j.join().expect("producer thread must join cleanly");
    }

    // Read all output; expect N lines, each containing
    // `wat-edn.holon/I64` + the integer payload.
    let deadline = Instant::now() + TEST_TIMEOUT;
    let bytes = read_until(&read_fd, 4096, deadline);
    let s = std::str::from_utf8(&bytes).expect("output must be valid UTF-8");
    let lines: Vec<&str> = s.split_inclusive('\n').collect();
    let payload_lines: Vec<&str> = lines
        .iter()
        .copied()
        .filter(|l| l.contains("wat-edn.holon/I64"))
        .collect();
    assert_eq!(
        payload_lines.len(),
        N,
        "expected N lines on output, one per producer; got {} lines in {:?}",
        payload_lines.len(),
        s
    );
    // Each producer's payload (0..N) must appear on its own line.
    // Cross-thread ordering is NOT guaranteed (Select picks
    // readiness; producers race) — collect into a set and verify
    // membership.
    use std::collections::HashSet;
    let seen: HashSet<i64> = payload_lines
        .iter()
        .filter_map(|l| {
            // tagged form: "#wat-edn.holon/I64 N\n"
            let t = l.trim_end();
            t.split_whitespace().last().and_then(|tok| tok.parse().ok())
        })
        .collect();
    let expected: HashSet<i64> = (0..N as i64).collect();
    assert_eq!(
        seen, expected,
        "every producer's integer must land in output; got seen={:?} expected={:?} raw={:?}",
        seen, expected, s
    );

    drop(handle);
    drop(read_fd);
    drop(write_fd);
}

