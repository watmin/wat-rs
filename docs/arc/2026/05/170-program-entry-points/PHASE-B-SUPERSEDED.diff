+// ─── Typed-channel output alternative to stdout capture ─────────────────
+
+#[test]
+fn spawn_process_typed_output_replaces_stdout_capture() {
+    // The original run-sandboxed-ast captured stdout from the inner main.
+    // Post-arc-170, the pattern is: inner process sends typed values via
+    // Sender<T>; parent receives them via process-recv. Verified here.
+    let src = r##"
+        (:wat::core::defn :my::hello-sender
+          [rx <- :wat::kernel::Receiver<wat::core::String>
+           tx <- :wat::kernel::Sender<wat::core::String>]
+          -> :wat::core::nil
+          (:wat::core::Result/expect -> :wat::core::nil
+            (:wat::kernel::send tx "hello")
+            "send failed"))
+
+        (:wat::core::defn :user::main
+          [stdin  <- :wat::io::IOReader
+           stdout <- :wat::io::IOWriter
+           stderr <- :wat::io::IOWriter
+           argv   <- :wat::core::Vector<wat::core::String>]
+          -> :wat::kernel::ExitCode
+          (:wat::core::let
+            [proc (:wat::kernel::spawn-process :my::hello-sender)
+             recv-result (:wat::kernel::process-recv proc)
+             s
+               (:wat::core::match recv-result -> :wat::core::String
+                 ((:wat::core::Ok (:wat::core::Some v)) v)
+                 ((:wat::core::Ok :wat::core::None) "")
+                 ((:wat::core::Err _died) ""))]
+            (:wat::io::IOWriter/println stdout s))
+          (:wat::core::u8 0))
+    "##;
+    assert_eq!(run(src), vec!["hello"]);
+}
